# Example environment for local development
# Replace these placeholder values with secure secrets before production

# Database API keys (use new names expected by the application)
APIKEY_MONGODB=example-secure-key
APIKEY_REDIS=example-secure-key
APIKEY_QDRANT=example-secure-key
APIKEY_MCP=example-secure-key

# Example hosts (adjust if running services in containers)
MONGODB_URL=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333
