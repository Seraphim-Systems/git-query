# Git-Query Environment Configuration
# Copy this file to .env and fill in your actual values

# ==============================================
# API Configuration (REQUIRED)
# ==============================================
# Your MongoDB API server URL
API_BASE_URL=https://your-api-server.com

# Your MongoDB API key
APIKEY_MONGODB=your_api_key_here

# ==============================================
# Training Configuration
# ==============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
BATCH_SIZE=32
FETCH_BATCH_SIZE=100
SKIP_IF_NO_NEW_DATA=true

# Optional: Limit repos for testing
# MAX_REPOS=1000

# Logging
LOG_LEVEL=INFO

# ==============================================
# Other Service Configurations (add as needed)
# ==============================================

