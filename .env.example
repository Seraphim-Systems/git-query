# Example environment for local development
# Replace these placeholder values with secure secrets before production

# Database API keys (must not be 'change-me' or 'dev-local-key')
MONGODB_API_KEY=example-secure-key
REDIS_API_KEY=example-secure-key
QDRANT_API_KEY_AUTH=example-secure-key
DATA_INGESTION_API_KEY=example-secure-key

# Example hosts (adjust if running services in containers)
MONGODB_URL=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333
