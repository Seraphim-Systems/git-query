# Service Versions (set in GitHub repository variables)
APP_VERSION=latest
CHAT_AGENT_VERSION=latest
RECOMMENDER_VERSION=latest
NGINX_VERSION=latest
DB_VERSION=latest

# Database
DATABASE_URL=postgresql://user:password@db:5432/gitquery
DB_USER=user
DB_PASSWORD=change_this_password
DB_NAME=gitquery

# Application Secrets
SECRET_KEY=change_this_secret_key
JWT_SECRET=change_this_jwt_secret
API_SECRET=change_this_api_secret

# External APIs
OPENAI_API_KEY=sk-your-openai-key-here

# Registry (for CI/CD)
REGISTRY_URL=ghcr.io
REGISTRY_USERNAME=your-github-username
REGISTRY_PASSWORD=your-github-token

# Production Server (for CI/CD)
PROD_HOST=your-server-ip
PROD_USER=deploy
PROD_SSH_KEY=your-ssh-private-key
