# Git-Query Environment Configuration
# Copy to .env and fill in your values. DO NOT commit .env.

# ==============================================
# Database connections (gateway + recommender)
# ==============================================
MONGODB_URL=mongodb://user:password@mongodb:27017/gitquery?authSource=admin
MONGODB_DB=gitquery
REDIS_URL=redis://:password@redis:6379
QDRANT_URL=http://qdrant:6333

# ==============================================
# Gateway API keys (protect DB endpoints)
# ==============================================
APIKEY_MONGODB=change-me
APIKEY_REDIS=change-me
APIKEY_QDRANT=change-me
APIKEY_MCP=change-me

# ==============================================
# LLM / OpenAI
# ==============================================
# Used by the MCP server and the client bot.
# Get your key from https://platform.openai.com/api-keys
APP_OPENAI_API_KEY=sk-...

# ==============================================
# Security
# ==============================================
JWT_SECRET=change-me-in-production

# ==============================================
# Recommender service
# ==============================================
# URL the MCP server uses to reach the recommender.
# In Docker this defaults to http://recommender:8095.
# When running locally, point it at localhost:
# RECOMMENDER_URL=http://localhost:8095

# ==============================================
# Training pipeline (Docker container)
# ==============================================
# URL of your running gateway
API_BASE_URL=https://your-gateway-url.com
# Training authenticates with APIKEY_MONGODB above
