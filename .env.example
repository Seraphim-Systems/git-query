# COSMOS_DB_KEY=your-primary-key-from-azure-portal

# =============================================================================
# Qdrant Configuration (Vector Database)
# =============================================================================
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Optional, set for production
QDRANT_LOG_LEVEL=INFO

# For production, consider using Qdrant Cloud
# QDRANT_URL=https://your-cluster-id.qdrant.io
# QDRANT_API_KEY=your-api-key-from-qdrant-cloud

# =============================================================================
# Redis Configuration (Cache Database)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-this-in-production  # Required for production

# For production, use Azure Cache for Redis
# REDIS_HOST=your-cache-name.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_URL=rediss://your-cache-name.redis.cache.windows.net:6380
# REDIS_PASSWORD=your-access-key-from-azure-portal

# =============================================================================
# Application Configuration
# =============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# =============================================================================
# API Keys
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
GITHUB_TOKEN=your-github-personal-access-token
DATA_INGESTION_API_KEY=your-secure-api-key-here-for-database-writes

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_NAME=localhost  # Or your domain name for production
NGINX_PORT=80

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO

# Processing Service Configuration
PROCESSING_LOG_LEVEL=INFO
PROCESSING_BATCH_SIZE=100
PROCESSING_INTERVAL=60

# Database URLs (already configured)
MONGODB_URL=mongodb://admin:pass@mongodb:27017/gitquery?authSource=admin
REDIS_URL=redis://:pass@redis:6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Processing Collections
PROCESSING_SOURCE_COLLECTION=raw_repositories
PROCESSING_DEST_COLLECTION=repositories
PROCESSING_VECTOR_COLLECTION=repository_embeddings

# Data Quality Rules
PROCESSING_MIN_DESCRIPTION_LENGTH=10
PROCESSING_MAX_DESCRIPTION_LENGTH=5000
