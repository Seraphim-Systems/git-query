# Git-Query Environment Configuration
# Copy to .env and fill in your values. DO NOT commit .env.

# ==============================================
# Database connections (gateway + recommender)
# ==============================================
MONGODB_URL=mongodb://user:password@mongodb:27017/gitquery?authSource=admin
MONGODB_DB=gitquery
REDIS_URL=redis://:password@redis:6379
QDRANT_URL=http://qdrant:6333

# ==============================================
# Gateway API keys (protect DB endpoints)
# ==============================================
APIKEY_MONGODB=change-me
APIKEY_REDIS=change-me
APIKEY_QDRANT=change-me
APIKEY_MCP=change-me

# ==============================================
# Security
# ==============================================
JWT_SECRET=change-me-in-production

