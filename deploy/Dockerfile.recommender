FROM python:3.11-slim

WORKDIR /app

# Install MCP and ML dependencies
RUN pip install --no-cache-dir mcp httpx pydantic numpy scikit-learn

# Copy MCP tool server code
COPY mcp_servers/recommender/ .
COPY recommenders/ ./recommenders/
COPY utils/ ./utils/

# Expose MCP server port (if using HTTP transport)
EXPOSE 8002

# Run MCP tool server
CMD ["python", "server.py"]
