# Database Configuration for Git-Query Chatbot
# Copy this file to .env and fill in your actual values

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=gitquery
DATABASE_URL=postgresql://user:pass@localhost:5432/gitquery

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=mongopass
MONGO_DB=gitquery
MONGODB_URL=mongodb://admin:mongopass@localhost:27017/gitquery?authSource=admin

# =============================================================================
# Azure Cosmos DB Configuration
# =============================================================================
# For local development, use the emulator endpoint
COSMOS_DB_URL=https://localhost:8081
COSMOS_DB_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
COSMOS_DB_NAME=gitquery_cosmos
COSMOS_PARTITION_COUNT=10
COSMOS_IP=127.0.0.1

# For production, use your actual Azure Cosmos DB connection string
# COSMOS_DB_URL=https://your-account.documents.azure.com:443/
# COSMOS_DB_KEY=your-primary-key-from-azure-portal

# =============================================================================
# Qdrant Configuration (Vector Database)
# =============================================================================
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Optional, set for production
QDRANT_LOG_LEVEL=INFO

# For production, consider using Qdrant Cloud
# QDRANT_URL=https://your-cluster-id.qdrant.io
# QDRANT_API_KEY=your-api-key-from-qdrant-cloud

# =============================================================================
# Redis Configuration (Cache Database)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=  # Optional, set for production

# For production, use Azure Cache for Redis
# REDIS_HOST=your-cache-name.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_URL=rediss://your-cache-name.redis.cache.windows.net:6380
# REDIS_PASSWORD=your-access-key-from-azure-portal

# =============================================================================
# Application Configuration
# =============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# =============================================================================
# API Keys
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
GITHUB_TOKEN=your-github-personal-access-token

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=True
LOG_LEVEL=INFO
