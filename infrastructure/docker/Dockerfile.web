FROM nginx:alpine

# Install curl for healthchecks
RUN apk add --no-cache curl

# Copy nginx configuration template
COPY web/nginx-db.conf.template /etc/nginx/templates/default.conf.template

# Create directories for data ingestion
RUN mkdir -p /var/www/data-ingestion

# Create web directory and copy static files if they exist
# Using || true to allow build to succeed if web files are not present (optional deployment)
RUN mkdir -p /usr/share/nginx/html
COPY web/ /usr/share/nginx/html/ 2>/dev/null || true

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]