# API Gateway Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
COPY src/gateway/requirements.txt gateway-requirements.txt
RUN pip install --no-cache-dir -r requirements.txt && \
  pip install --no-cache-dir -r gateway-requirements.txt

# Copy source code
COPY src/ src/

# Expose port
EXPOSE 8000

# Run API Gateway
CMD ["python", "-m", "uvicorn", "src.gateway.server:app", "--host", "0.0.0.0", "--port", "8000"]
