# git-query environment template
# Copy this file to infrastructure/docker/.env and fill in real values.
# DO NOT commit .env. This example file is safe to commit.
#
# For CI/CD, set these as GitHub Actions secrets (see .github/workflows/).

# ==============================================
# Database credentials
# ==============================================
DB_MONGODB_USER=admin
DB_MONGODB_PASSWORD=CHANGE_ME
DB_MONGODB_DATABASE=gitquery
DB_REDIS_PASSWORD=CHANGE_ME

# ==============================================
# Per-service API keys (protect internal gateway routes)
# ==============================================
APIKEY_MONGODB=CHANGE_ME
APIKEY_REDIS=CHANGE_ME
APIKEY_QDRANT=CHANGE_ME
APIKEY_MCP=CHANGE_ME

# ==============================================
# Application secrets
# ==============================================
APP_JWT_SECRET=CHANGE_ME
APP_SESSION_SECRET=CHANGE_ME
APP_OPENAI_API_KEY=sk-...

# ==============================================
# Admin seed user
# The gateway creates this user on first start if it does not already exist.
# Set these as GitHub secrets (WEB_ADMIN_EMAIL, WEB_ADMIN_PASSWORD,
# WEB_ADMIN_USERNAME) for automated deployment seeding.
# ==============================================
WEB_ADMIN_EMAIL=admin@gitquery.dev
WEB_ADMIN_PASSWORD=adminpassword
WEB_ADMIN_USERNAME=admin

# ==============================================
# Service configuration
# ==============================================
SVC_QDRANT_LOG_LEVEL=INFO
SVC_LOG_LEVEL=INFO

# Gateway rate limit secrets (set requests to 0 to disable/uncap)
GATEWAY_RATE_LIMIT_REQUESTS=0
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# Optional: server name for nginx/external proxy (leave blank or _ for local dev)
SVC_NGINX_SERVER_NAME=_

# ==============================================
# MLflow tracking server
# ==============================================
# Internal Docker DNS URL used by app/training containers.
MLFLOW_TRACKING_URI=http://mlflow:5000
# Host port for MLflow UI/API (change if 5000 is occupied on the server).
MLFLOW_PORT=5000
# Shared experiment defaults.
MLFLOW_EXPERIMENT_NAME=git-query-retrain
# Backend metadata store and artifact root for MLflow server.
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlflow/artifacts

# Notes:
# - Run all compose stacks from infrastructure/docker/ so this .env is
#   picked up automatically by docker-compose.
# - The dev compose maps gateway to host port 80; may require sudo or
#   freeing port 80 if already in use.
