# Example environment file for local development and compose
# Copy this file to infrastructure/docker/.env and customize values.

## Database credentials
DB_MONGODB_USER=admin
DB_MONGODB_PASSWORD=mongopass
DB_MONGODB_DATABASE=gitquery
DB_REDIS_PASSWORD=redispass
DB_COSMOS_PARTITION_COUNT=10
DB_QDRANT_API_KEY=

## Per-service API keys (used by various services)
APIKEY_MONGODB=dev-mongodb-key
APIKEY_REDIS=dev-redis-key
APIKEY_QDRANT=dev-qdrant-key
APIKEY_COSMODB=dev-cosmos-key

## Gateway-specific environment (prefixed with GATEWAY_ for pydantic settings)
# These values are what the Gateway expects via `GATEWAY_` env prefix.
GATEWAY_MONGODB_API_KEY=dev-mongodb-key
GATEWAY_REDIS_API_KEY=dev-redis-key
GATEWAY_QDRANT_API_KEY=dev-qdrant-key
GATEWAY_MCP_API_KEY=dev-mcp-key

## Application secrets
APP_JWT_SECRET=change-me-in-dev
APP_SESSION_SECRET=change-me-in-dev
APP_OPENAI_API_KEY=

## Service configuration
SVC_QDRANT_LOG_LEVEL=INFO
SVC_LOG_LEVEL=DEBUG

# Optional: domain name used by nginx/external proxy (not required for local dev)
SVC_NGINX_SERVER_NAME=_

# Notes:
# - Copy this file to infrastructure/docker/.env before running docker-compose.
# - The dev compose maps gateway to host port 80; running the compose may
#   require sudo or freeing port 80 if already in use.